---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<section id="contact" class="contact-section">
  <div class="container">
    <h2 class="contact-headline display">
      Let's talk about what you're building.
    </h2>
    <p class="contact-body">
      If you're working on something ambitious and think we'd work well together, I'd love to hear about it.
    </p>
    <div class="contact-links">
      <a href="mailto:hello@aaronbailey.co" class="contact-link">
        hello@aaronbailey.co
      </a>
      <a href="https://www.linkedin.com/in/arnbly/" class="contact-link" target="_blank" rel="noopener">
        LinkedIn
      </a>
      <a href={`${base}Aaron%20Bailey%20Resume%2026.pdf`} class="contact-link" target="_blank">
        Résumé
      </a>
    </div>
  </div>
</section>
